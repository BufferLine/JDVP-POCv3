{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bufferline.dev/schemas/pocv3/annotation_overlay.schema.json",
  "title": "POCv3 Annotation Overlay",
  "type": "object",
  "required": [
    "interaction_id",
    "turn_number",
    "track",
    "jsv",
    "evidence_spans"
  ],
  "properties": {
    "interaction_id": {
      "type": "string",
      "minLength": 1
    },
    "turn_number": {
      "type": "integer",
      "minimum": 0
    },
    "track": {
      "type": "object",
      "required": [
        "track_id"
      ],
      "properties": {
        "track_id": {
          "type": "string",
          "minLength": 1
        },
        "model_id": {
          "type": "string"
        },
        "prompt_version": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "jsv": {
      "type": "object"
    },
    "evidence_spans": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "text",
          "category"
        ],
        "properties": {
          "text": {
            "type": "string",
            "minLength": 1
          },
          "category": {
            "type": "string",
            "minLength": 1
          },
          "note": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "observer_confidence": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0
    },
    "observer_notes": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
